#!/bin/bash


scheme() {
    gsettings get org.gnome.desktop.interface color-scheme
}

swap_freedesktop() {
    # Toggle the FreeDesktop color-scheme preference — source of truth for everything else.
    if [ "$(scheme)" = "'prefer-dark'" ]; then
        gsettings set org.gnome.desktop.interface color-scheme 'prefer-light'
    else
        gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
    fi
}

swap_alacritty() {
    dir="$HOME/.config/alacritty"
    if [ "$(scheme)" = "'prefer-light'" ]; then
        ln -sf "$dir/everforest_light.toml" "$dir/theme.toml"
    else
        ln -sf "$dir/everforest_dark.toml" "$dir/theme.toml"
    fi
    # Trigger alacritty to reload the config
    touch "$dir/alacritty.toml"
}

swap_i3() {
    dir="/home/filip/dotfiles/i3"
    if [ "$(scheme)" = "'prefer-light'" ]; then
        ln -sf "$dir/themes/everforest-light" "$dir/theme"
        ln -sf "$dir/i3blocks-light.conf" "$dir/i3blocks.conf"
    else
        ln -sf "$dir/themes/everforest-dark" "$dir/theme"
        ln -sf "$dir/i3blocks-dark.conf" "$dir/i3blocks.conf"
    fi
    i3-msg reload &>/dev/null
    pkill i3bar
    i3bar &>/dev/null &
    disown
}

swap_tmux() {
    dir="$HOME/.config/tmux"
    if [ "$(scheme)" = "'prefer-light'" ]; then
        ln -sf "$dir/tmux-light.conf" "$dir/theme.conf"
    else
        ln -sf "$dir/tmux-dark.conf" "$dir/theme.conf"
    fi
    tmux source-file "$dir/tmux.conf"
}

swap_nvim() {
    # nvim uses 'light'/'dark' — extract from the prefer-light/prefer-dark value.
    # Signal all running nvim instances via their RPC sockets.
    bg=$(scheme | grep -o 'light\|dark')
    for socket in /run/user/$(id -u)/nvim.*.0; do
        [ -S "$socket" ] && nvim --server "$socket" --remote-expr "execute('set background=$bg')" &>/dev/null
    done
}

swap_gtk() {
    local xconf="$HOME/.config/xsettingsd/xsettingsd.conf"
    if [ "$(scheme)" = "'prefer-light'" ]; then
        gsettings set org.gnome.desktop.interface gtk-theme 'Current-Light'
        gsettings set org.gnome.desktop.interface icon-theme 'Current-Light'
        sed -i 's/^Net\/ThemeName .*/Net\/ThemeName "Current-Light"/' "$xconf"
        sed -i 's/^Net\/IconThemeName .*/Net\/IconThemeName "Current-Light"/' "$xconf"
    else
        gsettings set org.gnome.desktop.interface gtk-theme 'Current-Dark'
        gsettings set org.gnome.desktop.interface icon-theme 'Current-Dark'
        sed -i 's/^Net\/ThemeName .*/Net\/ThemeName "Current-Dark"/' "$xconf"
        sed -i 's/^Net\/IconThemeName .*/Net\/IconThemeName "Current-Dark"/' "$xconf"
    fi
    killall xsettingsd 2>/dev/null
    xsettingsd -c "$xconf" &
    disown
}

swap_freedesktop
swap_alacritty
swap_tmux
swap_i3
swap_nvim
swap_gtk
